GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
PORT=80
BD_PATH=/usr/local/bin/bd
LOG_LEVEL=info

# Path to your beads repository (where .beads/ directory lives)
BEADS_REPO_PATH=/root/.openclaw/workspace

